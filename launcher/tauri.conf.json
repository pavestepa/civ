{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Civ",
  "version": "0.1.0",
  "identifier": "com.civ.game",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Civ",
        "width": 1600,
        "height": 900,
        "transparent": true,
        "decorations": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
